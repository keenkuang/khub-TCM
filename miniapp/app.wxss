page { font-family: -apple-system, BlinkMacSystemFont, sans-serif; font-size: 14px; color: #333; background: #f5f5f5; }
.card { background: #fff; border-radius: 8px; padding: 12px 16px; margin: 8px 12px; box-shadow: 0 1px 4px rgba(0,0,0,0.06); }
.meta { font-size: 12px; color: #888; }
button.primary { background: #4488cc; color: #fff; border-radius: 6px; padding: 10px; width: 100%; }
.flex-row { display: flex; align-items: center; justify-content: space-between; }
